# Single-node Deployment Configuration Example

# AWS Configuration
S3_BUCKET="your-deployment-bucket"
AWS_REGION="ap-northeast-1"

# Instance Configuration (single-node)
INSTANCE_ID="i-xxxxxxxxxxxxx"
PRIVATE_IP="172.31.x.x"

# vLLM Configuration
MODEL_NAME="Qwen/Qwen2.5-32B-Instruct"
TENSOR_PARALLEL_SIZE="2"  # For g7e.12xlarge (2 GPUs)

# NIXL Configuration (for disaggregated mode)
UCX_TLS="tcp,self,sm"  # TCP + shared memory
KV_BUFFER_DEVICE="cpu"
KV_BUFFER_SIZE="10000000000"  # 10GB

# Ports (aggregated mode)
VLLM_PORT="8000"

# Ports (disaggregated mode)
PRODUCER_PORT="8100"
CONSUMER_PORT="8200"
PROXY_PORT="8000"
